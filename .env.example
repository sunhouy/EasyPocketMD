ADMIN_PASSWORD # Administrator account password
ADMIN_USER # Administrator account username
BASE_URL # Base URL of the application
DASHSCOPE_API_KEY # DashScope API key
DB_HOST # Database host address
DB_NAME # Database name
DB_PASSWORD # Database password
DB_PORT # Database port number
DB_USER # Database username
JKS_ALIAS # Alias for the Java KeyStore certificate
JKS_BASE64 # Base64-encoded Java KeyStore file content
JKS_PASSWORD # Password for the Java KeyStore
JWT_EXPIRES_IN # Expiration time for JWT tokens
JWT_SECRET # Secret key for signing JWT tokens
KEY # Private key for HTTPS
PEM # PEM-format certificate for HTTPS
PORT # Port on which the application listens
REDIS_DB # Redis database index
REDIS_HOST # Redis server host address
REDIS_PASSWORD # Redis server password
REDIS_PORT # Redis server port number
SERVER_HOST # API server host address
SERVER_PASSWORD # API server password
SERVER_USER # API server username