{
  "name": "easypocketmd",
  "version": "2.8.9",
  "description": "一款几乎零学习成本的 Markdown 编辑器：无需记忆语法，也能轻松插入格式化文本、LaTeX 公式和图表。配合智能搜索与 AI 助手，常用功能都能几步完成。实时协作、AI 辅助写作与流畅编辑体验，全部整合在美观的界面中。",
  "scripts": {
    "dev": "vite",
    "build": "npm run wasm:text:build && npm run wasm:image:build && node version.js && vite build && npm run wasm:text:verify:dist && npm run wasm:image:verify:dist",
    "build:web": "node version.js && vite build",
    "test": "NODE_ENV=test jest --config jest.config.js --runInBand --forceExit",
    "front-test": "NODE_ENV=test jest --config jest.config.ts --runInBand --forceExit",
    "check-deploy": "node scripts/check-deploy.js",
    "start": "node api/server.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build --apk",
    "tauri:android:run": "tauri android run",
    "build:tauri": "tauri build",
    "build:tauri:win": "tauri build --bundles nsis",
    "build:tauri:linux": "tauri build --bundles deb,appimage",
    "build:tauri:mac": "tauri build --bundles dmg",
    "bump-version": "node version.js",
    "wasm:text:build": "bash wasm_text_engine/scripts/build_wasm.sh",
    "wasm:text:verify": "node scripts/verify-wasm-artifacts.js source",
    "wasm:text:verify:dist": "node scripts/verify-wasm-artifacts.js dist",
    "wasm:image:build": "bash wasm_text_engine/scripts/build_image_compressor.sh",
    "wasm:image:verify": "node scripts/verify-wasm-artifacts.js source image",
    "wasm:image:verify:dist": "node scripts/verify-wasm-artifacts.js dist image"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunhouy/EasyPocketMD.git"
  },
  "keywords": [],
  "author": {
    "name": "sunhouyun",
    "email": "sunhouyun@emails.bjut.edu.cn"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sunhouy/EasyPocketMD/issues"
  },
  "homepage": "https://yhsun.cn/",
  "overrides": {
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "cropperjs": "^1.6.2",
    "dom-to-image": "^2.6.0",
    "dotenv": "^16.3.1",
    "echarts": "^6.0.0",
    "eruda": "^3.4.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "html-to-pdfmake": "^2.5.33",
    "html-to-pptx": "^1.1.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "ioredis": "^5.10.1",
    "jquery": "^3.7.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jstree": "^3.3.17",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.1.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mathjax3": "^5.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "marked": "^12.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "node-fetch": "^3.3.2",
    "pdfjs-dist": "^4.4.168",
    "pdfmake": "^0.3.7",
    "pdfmake-support-chinese-fonts": "^1.0.3",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sensitive-word-filter": "^1.0.2",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "vditor": "^3.11.2",
    "wkhtmltopdf": "^0.4.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-migrate": "^0.1.35",
    "vite": "7.3.1",
    "vite-plugin-static-copy": "^3.2.0"
  }
}
