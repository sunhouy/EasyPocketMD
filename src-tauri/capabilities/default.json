{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Main window access for editing, file dialogs and file system operations.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "http:default",
    "opener:allow-open-url",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    "fs:allow-mkdir",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "mailto:*" },
        { "url": "tel:*" },
        { "url": "*://*" }
      ]
    }
  ]
}